# Copy this to .env.local and fill in real values.
# Never commit .env.local — it's already in .gitignore.

# Turso DB — get from `turso db show eurokaefer-db` and `turso db tokens create eurokaefer-db`
TURSO_URL=libsql://eurokaefer-db-<yourname>.turso.io
TURSO_TOKEN=

# GitHub PAT for triggering the refresh workflow.
# Settings → Developer settings → Personal access tokens → Fine-grained tokens.
# Scope: this repo, "Actions: read+write", "Contents: read+write".
GH_PAT=
GH_REPO=<your-github-username>/eurokaefer
